{
  "name": "roam-research-cli",
  "version": "0.3.0",
  "description": "A CLI for the Roam Research APIs (Backend + Append + Desktop Local), designed to be friendly to humans and AI agents.",
  "type": "module",
  "bin": {
    "roam": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test test/*.test.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "roam",
    "roam-research",
    "cli",
    "datalog",
    "ai",
    "knowledge-graph"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
